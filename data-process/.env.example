# LLM 配置（阶段一摘要 + 阶段三命名共用 API）
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=GLM-5.1          # 阶段一摘要用的模型
NAME_MODEL=GLM-5             # 阶段三命名用的模型，可稍弱

# 百度千帆 Embedding 配置
EMBEDDING_API_KEY=your-embedding-key-here
EMBEDDING_URL=https://qianfan.baidubce.com/v2/embeddings
